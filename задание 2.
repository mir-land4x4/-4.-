#define LATCH 4   // ST_CP (защелка) 74HC595
#define CLK   7   // SH_CP (тактовый вход)
#define DATA  8   // DS (вход данных)

// Коды цифр для семисегментного индикатора с общим анодом (0 - сегмент горит)
byte digits[] = {
  0xC0, 0xF9, 0xA4, 0xB0,  // 0,1,2,3
  0x99, 0x92, 0x82, 0xF8,  // 4,5,6,7
  0x80, 0x90               // 8,9
};

// Коды выбора разряда (активный низкий уровень, каждый бит включает один разряд)
byte pos[] = {
  0xF1,  // 1-й разряд (крайний левый)
  0xF2,  // 2-й
  0xF4,  // 3-й
  0xF8   // 4-й (крайний правый)
};

void setup() {
  // Настраиваем управляющие пины на вывод
  pinMode(LATCH, OUTPUT);
  pinMode(CLK, OUTPUT);
  pinMode(DATA, OUTPUT);
}

// Функция вывода одной цифры в заданный разряд
// position: 0..3 (номер разряда)
// num: 0..9 (цифра для отображения)
void showDigit(int position, int num) {
  digitalWrite(LATCH, LOW);               // Начинаем передачу данных

  // Сначала отправляем код сегментов (какие сегменты зажечь)
  shiftOut(DATA, CLK, MSBFIRST, digits[num]);
  // Затем отправляем код активного разряда (какой индикатор включить)
  shiftOut(DATA, CLK, MSBFIRST, pos[position]);

  digitalWrite(LATCH, HIGH);              // Фиксируем данные на выходах
}

// Функция отображения четырёхзначного числа методом динамической индикации
void displayNumber(int num) {
  // Выводим тысячи
  showDigit(0, num / 1000);
  delay(2);                               // Небольшая задержка для яркости
  // Выводим сотни
  showDigit(1, (num / 100) % 10);
  delay(2);
  // Выводим десятки
  showDigit(2, (num / 10) % 10);
  delay(2);
  // Выводим единицы
  showDigit(3, num % 10);
  delay(2);
}

void loop() {
  // Перебираем все числа от 0 до 9999
  for(int i = 0; i < 10000; i++) {
    // Каждое число отображаем многократно (50 раз) для устойчивого свечения
    for(int t = 0; t < 50; t++) {
      displayNumber(i);
    }
  }
}
